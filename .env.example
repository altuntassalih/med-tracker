# Firebase Ayarları
# Firebase Console'dan https://console.firebase.google.com aldığınız değerleri buraya girin
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID_HERE
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID_HERE

# Gemini API Anahtarı
# https://aistudio.google.com/app/apikey adresinden ücretsiz alabilirsiniz
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Google Sign-In Web Client ID
# Firebase Console -> Google Sign-in method -> Web SDK configuration kısmından alabilirsiniz
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID_HERE

# CollectAPI Nöbetçi Eczane API Anahtarı
# https://collectapi.com/tr adresinden ücretsiz alabilirsiniz
EXPO_PUBLIC_COLLECTAPI_KEY=YOUR_COLLECTAPI_KEY_HERE

# NosyAPI Tüm Eczaneler API Anahtarı
# https://www.nosyapi.com adresinden ücretsiz alabilirsiniz
EXPO_PUBLIC_NOSYAPI_KEY=YOUR_NOSYAPI_KEY_HERE
